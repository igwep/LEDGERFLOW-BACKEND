{
  "info": {
    "name": "LedgerFlow Paystack - Port 5000 Main Server",
    "description": "Paystack Integration on Main Server (Port 5000)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "paymentEndpoint",
      "value": "pay_testuser_ooz",
      "type": "string"
    },
    {
      "key": "reference",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🏦 Main Server Paystack Flow",
      "item": [
        {
          "name": "1️⃣ Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2️⃣ Initialize Paystack Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-idempotency-key",
                "value": "{{$randomUUID}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"description\": \"Test payment on main server\",\n  \"customerEmail\": \"test@example.com\",\n  \"redirectUrl\": \"https://example.com/success\",\n  \"metadata\": {\n    \"plan\": \"premium\",\n    \"userId\": \"test_user_123\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/payments/{{paymentEndpoint}}/paystack",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "{{paymentEndpoint}}",
                "paystack"
              ]
            }
          },
          "response": []
        },
        {
          "name": "3️⃣ Verify Payment Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payments/verify/{{reference}}/paystack",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "verify",
                "{{reference}}",
                "paystack"
              ]
            }
          },
          "response": []
        },
        {
          "name": "4️⃣ Test Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"charge.success\",\n  \"data\": {\n    \"id\": 123456789,\n    \"reference\": \"PAY_{{paymentEndpoint}}_{{randomUUID}}\",\n    \"amount\": 500000,\n    \"currency\": \"NGN\",\n    \"status\": \"success\",\n    \"gateway_response\": \"Successful\",\n    \"paid_at\": \"2023-12-01T10:30:00Z\",\n    \"customer\": {\n      \"email\": \"test@example.com\",\n      \"customer_code\": \"CUS_xxxxxx\"\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/webhooks/paystack",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "webhooks",
                "paystack"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
