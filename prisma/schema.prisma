// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Transaction types as strings instead of enum
// enum TransactionType {
//   CREDIT
//   DEBIT
// }

// Transaction statuses as strings instead of enum  
// enum TransactionStatus {
//   PENDING
//   SUCCESS
//   FAILED
//   REVERSED
// }

// Withdrawal statuses as strings instead of enum
// enum WithdrawalStatus {
//   PENDING
//   PROCESSING
//   SUCCESS
//   FAILED
// }

// Fraud levels as strings instead of enum
// enum FraudLevel {
//   LOW
//   MEDIUM
//   HIGH
// }

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  name            String?
  role            String   @default("MERCHANT")
  paymentEndpoint String   @unique // e.g., "pay_john123"

  wallet          Wallet?
  transactions    Transaction[]
  withdrawals     Withdrawal[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])

  balance       Float    @default(0)
  available     Float    @default(0)
  lockedBalance Float    @default(0)
  currency      String   @default("NGN")
  status        String   @default("ACTIVE")
  version       Int      @default(0) // For optimistic locking

  ledgerEntries LedgerEntry[]
  fraudScores   FraudScore[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("wallets")
}

model Transaction {
  id              String            @id @default(uuid())
  reference       String            @unique
  userId          String
  user            User              @relation(fields: [userId], references: [id])

  amount          Float     @default(0)
  currency        String            @default("NGN")
  type            String            // "CREDIT" or "DEBIT"
  status          String            @default("PENDING") // "PENDING", "SUCCESS", "FAILED", "REVERSED"

  provider        String?           // Paystack, VTU, etc.
  providerRef     String?           // Paystack reference
  description     String?
  metadata        String?           // Changed from Json to String
  idempotencyKey  String?           @unique

  processedAt     DateTime?         // When transaction was processed
  expiresAt       DateTime?         // Transaction expiration time

  ledgerEntries   LedgerEntry[]
  fraudScore      FraudScore?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([reference])
  @@index([status])
  @@index([provider])
  @@index([idempotencyKey])
  @@map("transactions")
}

model LedgerEntry {
  id             String       @id @default(uuid())
  walletId       String
  wallet         Wallet       @relation(fields: [walletId], references: [id])

  transactionId  String
  transaction    Transaction  @relation(fields: [transactionId], references: [id])

  type           String       // 'CREDIT' or 'DEBIT'
  amount         Float     @default(0)
  balanceBefore  Float     @default(0)
  balanceAfter   Float     @default(0)
  description    String?
  reference      String?      // External reference

  createdAt      DateTime     @default(now())

  @@index([walletId])
  @@index([transactionId])
  @@index([type])
  @@map("ledger_entries")
}

model Withdrawal {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])

  amount      Float     @default(0)
  status      String @default("PENDING") // "PENDING", "PROCESSING", "SUCCESS", "FAILED"

  bankName    String
  accountNumber String
  transferRef String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FraudScore {
  id             String     @id @default(uuid())
  walletId       String
  wallet         Wallet     @relation(fields: [walletId], references: [id])
  
  transactionId  String     @unique
  transaction    Transaction @relation(fields: [transactionId], references: [id])

  score          Float      // 0-100, higher = more risky
  level          String     // "LOW", "MEDIUM", "HIGH"
  flagged        Boolean    @default(false)
  
  factors        String?    // Changed from Json to String
  ipAddress      String?
  deviceId       String?
  location       String?    // Changed from Json to String
  userAgent      String?

  createdAt      DateTime @default(now())

  @@index([walletId])
  @@index([transactionId])
  @@index([level])
  @@index([flagged])
  @@map("fraud_scores")
}

model IdempotencyKey {
  id            String      @id @default(uuid())
  key           String      @unique
  transactionId String?
  
  response      String?       // Changed from Json to String
  statusCode     Int?        // HTTP status code
  expiresAt     DateTime?   // Expiration time for cleanup

  createdAt     DateTime @default(now())

  @@index([key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model WebhookEvent {
  id          String   @id @default(uuid())
  provider    String
  eventType   String
  payload     String   // Changed from Json to String
  signature   String?  // Provider signature for verification
  processed   Boolean  @default(false)
  processingAttempts Int @default(0)
  error       String?  // Last processing error
  processedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([provider])
  @@index([processed])
  @@index([eventType])
  @@map("webhook_events")
}