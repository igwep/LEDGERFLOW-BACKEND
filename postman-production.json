{
  "info": {
    "name": "LedgerFlow Paystack - Production",
    "description": "Production Paystack Integration - Single Server",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://ledgerflow-api.onrender.com/api",
      "type": "string"
    },
    {
      "key": "paymentEndpoint",
      "value": "test_merchant_123",
      "type": "string"
    },
    {
      "key": "reference",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🏦 Production Paystack Flow",
      "item": [
        {
          "name": "1️⃣ Initialize Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"description\": \"Production payment test\",\n  \"customerEmail\": \"test@example.com\",\n  \"redirectUrl\": \"https://example.com/success\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/payments/{{paymentEndpoint}}/paystack",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "{{paymentEndpoint}}",
                "paystack"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2️⃣ Verify Payment",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payments/verify/{{reference}}/paystack",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "verify",
                "{{reference}}",
                "paystack"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
